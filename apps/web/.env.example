# Copy this file to apps/web/.env and fill in real values.
# Schema source of truth: packages/env/src/server.ts + packages/env/src/web.ts

# ============================================================
# Database (Supabase Postgres)
# ============================================================
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ============================================================
# Better Auth — instância ecommerce (cliente BR)
# ============================================================
# Secret: gere com `openssl rand -base64 32` (mínimo 32 chars)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_URL_ECOMMERCE=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
ECOMMERCE_ORIGIN=http://localhost:3001

# OAuth Google (UI placeholder atualmente — backend pendente)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Email (Resend)
# ============================================================
# Domínio emachferramentas.com.br já verificado no Resend (sending habilitado).
# Sandbox (onboarding@resend.dev) só entrega pro owner — usar o domínio verificado.
RESEND_API_KEY=re_
EMAIL_FROM="EMACH <nao-responder@emachferramentas.com.br>"

# ============================================================
# Supabase
# ============================================================
SUPABASE_SERVICE_ROLE_KEY=sb_secret_
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co

# ============================================================
NODE_ENV=development

# ============================================================
# Client (NEXT_PUBLIC_*)
# ============================================================
NEXT_PUBLIC_ECOMMERCE_AUTH_URL=http://localhost:3001
# Google Maps Embed API. Restrinja a chave por HTTP referrer no Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
